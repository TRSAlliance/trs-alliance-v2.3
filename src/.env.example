# === Required for Netlify Build ===
NODE_ENV=production

# === TRS Alliance Core Secrets ===
TRS_BLOOD_SEAL=your_trs_blood_seal
TRS_DEPLOY_TOKEN=your_trs_deploy_token

# === Supabase Config ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# === Firebase Config ===
FIREBASE_PROJECT=trs-operator-live
FIREBASE_TOKEN=your_firebase_token

# === API Keys ===
OPENAI_API_KEY=your_openai_key
SPECIAL_ACCESS_TOKEN=your_special_token
DEPLOY_KEY=your_arweave_deploy_key
ANT_PROCESS=your_ant_process_id
UNDERNAME=@

# === Netlify (for CLI/manual deploys) ===
NETLIFY_AUTH_TOKEN=your_netlify_auth_token
NETLIFY_SITE_ID=your_netlify_site_id
